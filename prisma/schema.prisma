// EcoFlow / GreenEco CRM — core schema (Master Build Spec §5).
// Every model: companyId (tenant-ready), timestamps, audit via AuditLog.
// Postgres 16+ required: @db.Decimal money + String[] scalar lists.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum LeadStatus {
  NEW
  IN_FOLLOWUP
  QUOTE_REQUESTED
  CONVERTED
  LOST
  ON_HOLD
}

enum FollowUpType {
  CALL
  SITE_VISIT
  WHATSAPP
  EMAIL
  MEETING
}

enum FollowUpOutcome {
  INTERESTED
  NEEDS_TIME
  PRICE_DISCUSSION
  NOT_REACHABLE
  NEGATIVE
}

enum ProposalStatus {
  DRAFT
  SENT
  UNDER_NEGOTIATION
  WON
  LOST
  EXPIRED
}

enum OrderStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum StageStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum DrawingStatus {
  DRAFT
  FOR_APPROVAL
  APPROVED
  SUPERSEDED
}

enum MilestoneStatus {
  UPCOMING
  DUE
  PARTIALLY_PAID
  PAID
}

enum POStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
}

enum LocationType {
  WAREHOUSE
  SITE
}

enum MovementType {
  GRN
  TRANSFER_OUT
  TRANSFER_IN
  CONSUME
  ADJUST
  RETURN
}

enum ErectionType {
  LABOUR
  SITE_PURCHASE
  OTHER
}

enum EntryStatus {
  PENDING
  APPROVED
  QUERIED
  REJECTED
}

model User {
  id           String   @id // Clerk userId (or dev-shim id)
  companyId    String
  name         String
  phone        String
  email        String?  @unique // credentials-login identity
  passwordHash String? // scrypt hash (credentials login)
  role         Role     @default(EMPLOYEE)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([companyId])
}

model Lead {
  id           String     @id @default(cuid())
  companyId    String
  customerName String
  address      String
  lat          Float?
  lng          Float?
  phone        String // duplicate-check key
  email        String?
  source       String // Reference | SiteVisit | CallIn | Builder | Consultant | Other
  requirement  String? // free-text notes (structured sizing lives in the fields below)
  status       LeadStatus @default(NEW)
  lostReason   String?
  assignedToId String
  referenceId  String?

  // Structured plant-sizing (spec §7.1) — captured at the lead stage so the
  // pipeline can be filtered/analyzed by KLD and a BOQ band previewed pre-quote.
  // All nullable: pre-P2 leads have none; convertToProposal coalesces defaults.
  plantType        String? // STP | ETP | WTP
  technology       String? // MBBR | SBR | MBR | ASP | SAFF
  capacityKLD      Float? //  central sizing dimension (kilolitres/day)
  segment          String? // Apartment | Textile | Hospital | Hotel | ITPark | Industrial | Municipal | Institution
  budgetBand       String? // indicative budget band
  decisionTimeline String? // expected decision timeframe
  // Inlet water quality — needed to size a plant (mg/l except flow).
  inletBOD Float?
  inletCOD Float?
  inletTSS Float?
  inletTDS Float?

  reference      Reference?      @relation(fields: [referenceId], references: [id])
  contacts       ContactPerson[]
  followUps      FollowUp[]
  communications Communication[]
  documents      LeadDocument[]
  proposal       Proposal?
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  @@index([companyId, status])
  @@index([phone])
}

/**
 * Communication log (spec §7.1) — calls / WhatsApp / email against a lead, both
 * outbound (logged or app-sent) and inbound (webhook). Distinct from FollowUp
 * (which schedules a next action); a Communication is a record of a touch.
 */
model Communication {
  id          String   @id @default(cuid())
  companyId   String
  leadId      String? // set for lead comms
  proposalId  String? // set for proposal comms (send-to-client tracking)
  orderId     String? // set for project comms (execution client-comms)
  contractId  String? // set for AMC/service client-comms
  channel     String // CALL | WHATSAPP | EMAIL
  direction   String // OUT | IN
  body        String
  toAddress   String? // phone or email the message went to / came from
  subject     String? // email subject
  sentStatus  String? // SENT | FAILED | LOGGED | RECEIVED
  createdById String
  createdAt   DateTime @default(now())

  lead     Lead?            @relation(fields: [leadId], references: [id])
  proposal Proposal?        @relation(fields: [proposalId], references: [id])
  order    Order?           @relation(fields: [orderId], references: [id])
  contract ServiceContract? @relation(fields: [contractId], references: [id])

  @@index([leadId])
  @@index([proposalId])
  @@index([orderId])
  @@index([contractId])
  @@index([companyId, channel])
}

/** Documents attached to a proposal — signed copy, client PO, revised drawings, tender docs. */
model ProposalDocument {
  id          String   @id @default(cuid())
  companyId   String
  proposalId  String
  url         String
  name        String
  createdById String
  createdAt   DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id])

  @@index([proposalId])
}

/** Documents attached to a lead — site photos, water-test reports, tender/RFQ PDFs, drawings. */
model LeadDocument {
  id          String   @id @default(cuid())
  companyId   String
  leadId      String
  url         String
  name        String
  createdById String
  createdAt   DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([leadId])
}

model ContactPerson {
  id          String  @id @default(cuid())
  leadId      String?
  clientId    String?
  name        String
  designation String? // Manager, Association Secretary, etc.
  mobile      String

  lead Lead? @relation(fields: [leadId], references: [id])
}

model Reference {
  id        String  @id @default(cuid())
  companyId String
  name      String
  address   String?
  phone     String?
  email     String?
  leads     Lead[] // powers reference analytics
}

model FollowUp {
  id            String           @id @default(cuid())
  leadId        String?
  proposalId    String? // same engine reused post-quote
  datetime      DateTime         @default(now())
  type          FollowUpType
  notes         String // cleaned text (editable)
  rawTranscript String?
  audioUrl      String? // purge after 90 days (cron)
  lat           Float?
  lng           Float?
  geoAddress    String? // reverse-geocoded
  outcome       FollowUpOutcome?
  nextDate      DateTime? // MANDATORY unless lead is being closed
  attachments   Json? // [{url, name}]
  createdById   String
  createdAt     DateTime         @default(now())

  lead     Lead?     @relation(fields: [leadId], references: [id])
  proposal Proposal? @relation(fields: [proposalId], references: [id])

  @@index([leadId])
  @@index([proposalId])
  @@index([nextDate])
}

model Proposal {
  id             String            @id @default(cuid())
  companyId      String
  number         String            @unique // GEC-PRO-2026-001
  leadId         String            @unique
  projectName    String
  siteAddress    String
  plantType      String // STP | ETP | WTP
  technology     String // MBBR | SBR | MBR | ASP | ...
  capacityKLD    Float
  status         ProposalStatus    @default(DRAFT)
  lostReason     String? // required on LOST — feeds AI learning loop
  currentVersion Int               @default(1)
  versions       ProposalVersion[]
  followUps      FollowUp[]
  communications Communication[]
  documents      ProposalDocument[]
  order          Order?
  createdById    String
  createdAt      DateTime          @default(now())

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([companyId, status])
}

model ProposalVersion {
  id            String    @id @default(cuid())
  proposalId    String
  versionNo     Int
  scopeOfWork   Json // {civil, mechanical, electrical, commissioning, exclusions}
  technicalText String // AI-generated write-up (marked until reviewed)
  boqItems      BOQItem[]
  subtotal      Decimal   @db.Decimal(14, 2)
  gstAmount     Decimal   @db.Decimal(14, 2)
  grandTotal    Decimal   @db.Decimal(14, 2)
  estimatedCost Decimal?  @db.Decimal(14, 2) // ADMIN-ONLY — margin guard
  paymentTerms  Json // [{description, percent, trigger}]
  terms         Json
  validityDays  Int       @default(30)
  changeNote    String?
  approvedById  String? // admin approval before send
  pdfUrl        String?
  aiGenerated   Boolean   @default(false)
  createdAt     DateTime  @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id])

  @@unique([proposalId, versionNo])
}

model BOQItem {
  id            String  @id @default(cuid())
  versionId     String
  category      String // Civil | Piping | PumpsBlowers | Media | Electrical | Others
  item          String
  specification String?
  unit          String
  qty           Decimal @db.Decimal(12, 3)
  rate          Decimal @db.Decimal(12, 2)
  amount        Decimal @db.Decimal(14, 2)
  aiSuggested   Boolean @default(false) // shows "review" badge until edited/confirmed

  version ProposalVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
}

model Order {
  id           String      @id @default(cuid())
  companyId    String
  orderNo      String      @unique // GEC-ORD-2026-001
  proposalId   String      @unique
  clientName      String
  siteAddress     String
  clientStateCode String? // 2-digit GSTIN state prefix for place-of-supply (IGST vs CGST/SGST)
  clientGstin     String? // customer GSTIN for the B2B tax invoice
  projectValue    Decimal     @db.Decimal(14, 2)
  startDate    DateTime?
  targetDate   DateTime?
  status       OrderStatus @default(ACTIVE)

  team             TeamAssignment[]
  stages           Stage[]
  drawings         Drawing[]
  milestones       PaymentMilestone[]
  documents        Document[]
  communications   Communication[]
  erectionEntries  ErectionEntry[]
  budget           Budget?
  siteLocation     Location? // auto-created SITE location for stock
  materialRequests MaterialRequest[]
  serviceContracts ServiceContract[]
  createdAt        DateTime           @default(now())
  deletedAt        DateTime? // archive / soft-delete

  proposal Proposal @relation(fields: [proposalId], references: [id])

  @@index([companyId, status])
}

model TeamAssignment {
  id      String @id @default(cuid())
  orderId String
  userId  String
  role    String // PROJECT_MANAGER | CIVIL_ENGINEER | SUPERVISOR

  order Order @relation(fields: [orderId], references: [id])

  @@unique([orderId, userId])
  @@index([userId])
}

model Stage {
  id          String       @id @default(cuid())
  orderId     String
  seq         Int
  name        String // from 9-stage default template (seed)
  plannedDate DateTime?
  actualDate  DateTime?
  status      StageStatus  @default(PENDING)
  delayReason String?
  notes       String?
  photos      StagePhoto[]

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model StagePhoto {
  id       String   @id @default(cuid())
  stageId  String
  url      String
  lat      Float?
  lng      Float?
  takenAt  DateTime @default(now())
  byUserId String

  stage Stage @relation(fields: [stageId], references: [id])
}

model Drawing {
  id             String        @id @default(cuid())
  orderId        String
  title          String
  discipline     String // Structural | Piping | Electrical | Layout
  revision       String // A, B, C...
  fileUrl        String
  approvalStatus DrawingStatus @default(DRAFT)
  changeNote     String?
  isCurrent      Boolean       @default(true) // re-upload same title → old rev isCurrent=false, SUPERSEDED
  uploadedById   String
  createdAt      DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId, title])
}

model PaymentMilestone {
  id            String          @id @default(cuid())
  orderId       String
  seq           Int
  description   String // "50% Advance", "30% on equipment delivery"
  amount        Decimal         @db.Decimal(14, 2)
  dueBasis      String // DATE | STAGE_COMPLETION
  dueDate       DateTime?
  linkedStageId String?
  status        MilestoneStatus @default(UPCOMING)
  receipts      Receipt[]
  invoice       Invoice?

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Receipt {
  id          String   @id @default(cuid())
  milestoneId String
  date        DateTime
  amount      Decimal  @db.Decimal(14, 2)
  mode        String // CASH | CHEQUE | NEFT | UPI
  refNo       String?
  note        String?
  createdById String // ADMIN only

  milestone PaymentMilestone @relation(fields: [milestoneId], references: [id])

  @@index([milestoneId])
}

model Invoice {
  id           String   @id @default(cuid())
  companyId    String
  invoiceNo    String   @unique // GEC-INV-2026-###  (sequential, never reused)
  orderId      String
  milestoneId  String?  @unique
  date         DateTime
  lineItems    Json
  taxType      String // CGST_SGST | IGST (place-of-supply)
  gstBreakup   Json // {cgst, sgst, igst, rate}
  total        Decimal  @db.Decimal(14, 2)
  amountWords  String
  pdfUrl         String
  isCreditNote   Boolean  @default(false)
  creditNoteOfId String? // the original invoice this credit note reverses

  milestone   PaymentMilestone? @relation(fields: [milestoneId], references: [id])
  creditNoteOf Invoice?         @relation("CreditNote", fields: [creditNoteOfId], references: [id])
  creditNotes  Invoice[]        @relation("CreditNote")

  @@index([companyId])
  @@index([orderId])
  @@index([creditNoteOfId])
}

model Item {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  category      String // Plumbing | Civil | PumpsMotors | Blowers | Electrical | MediaConsumables | Tools
  specification String?
  unit          String // nos | m | kg | bag
  reorderLevel  Decimal  @default(0) @db.Decimal(12, 3)
  purchasePrice Decimal? @db.Decimal(12, 2) // *** ADMIN-ONLY — strip for EMPLOYEE ***

  vendorPrices VendorPrice[]
  movements    StockMovement[]

  @@index([companyId, category])
}

model Vendor {
  id         String          @id @default(cuid())
  companyId  String
  name       String
  categories String[] // filters vendor list per PO item category
  contact    String?
  phone      String
  address    String?
  gstin      String?
  terms      String?
  rating     Int?
  pos        PurchaseOrder[]

  @@index([companyId])
}

model VendorPrice {
  id       String   @id @default(cuid())
  itemId   String
  vendorId String
  rate     Decimal  @db.Decimal(12, 2)
  poId     String
  date     DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id])

  @@index([itemId, vendorId])
}

model Location {
  id        String       @id @default(cuid())
  companyId String
  type      LocationType
  name      String // "Main Warehouse", "Warehouse 2", or site = orderNo
  orderId   String?      @unique // set when type=SITE

  order Order? @relation(fields: [orderId], references: [id])

  @@index([companyId, type])
}

model PurchaseOrder {
  id            String   @id @default(cuid())
  companyId     String
  poNo          String   @unique // GEC-PO-2026-###
  vendorId      String
  destinationId String // Location (warehouse OR site)
  expectedDate  DateTime
  status        POStatus @default(DRAFT)
  items         Json // [{itemId, qty, rate}]  rate ADMIN-ONLY
  totalValue    Decimal  @db.Decimal(14, 2) // ADMIN-ONLY
  pdfUrl        String?
  grns          GRN[]
  createdById   String
  createdAt     DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([companyId, status])
}

model GRN {
  id           String   @id @default(cuid())
  grnNo        String?  @unique // GEC-GRN-2026-001 (nullable: pre-numbering GRNs stay null)
  poId         String
  date         DateTime @default(now())
  items        Json // [{itemId, receivedQty}]  partial allowed
  challanUrl   String? // delivery challan photo
  receivedById String

  po PurchaseOrder @relation(fields: [poId], references: [id])

  @@index([poId])
}

// IMMUTABLE LEDGER — never update/delete; balances are derived.
model StockMovement {
  id             String       @id @default(cuid())
  companyId      String
  itemId         String
  qty            Decimal      @db.Decimal(12, 3)
  type           MovementType
  fromLocationId String?
  toLocationId   String?
  refDocType     String? // GRN | TRANSFER | ERECTION | AUDIT
  refDocId       String?
  valueAtCost    Decimal?     @db.Decimal(14, 2) // ADMIN-ONLY (consumption → project actuals)
  note           String?
  createdById    String
  createdAt      DateTime     @default(now())

  item Item @relation(fields: [itemId], references: [id])

  @@index([itemId, toLocationId])
  @@index([itemId, fromLocationId])
}

model MaterialRequest {
  id            String   @id @default(cuid())
  orderId       String
  items         Json // [{itemId, qty}] — NO prices ever
  status        String   @default("PENDING") // PENDING | CONVERTED_PO | TRANSFERRED | REJECTED
  requestedById String
  createdAt     DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model ErectionEntry {
  id           String       @id @default(cuid())
  orderId      String // ALWAYS starts by choosing project
  type         ErectionType
  date         DateTime
  description  String // "tank shuttering — 4 masons, 6 helpers"
  gangOrShop   String? // contractor name / shop name
  amount       Decimal      @db.Decimal(14, 2)
  paymentMode  String?
  billImages   Json // [{url}] — MANDATORY for SITE_PURCHASE
  status       EntryStatus  @default(PENDING)
  adminNote    String?
  createdById  String
  reviewedById String?
  createdAt    DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId, status])
}

model Budget {
  id          String  @id @default(cuid())
  orderId     String  @unique
  baseAmount  Decimal @db.Decimal(14, 2) // seeded from winning version estimatedCost
  adjustments Json // [{amount, reason, byUserId, date}]

  order Order @relation(fields: [orderId], references: [id])
}

model Document {
  id           String   @id @default(cuid())
  orderId      String
  title        String
  fileUrl      String
  kind         String? // Contract | Permit | Photo | Report | Other
  uploadedById String
  createdAt    DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  action    String // CREATE | UPDATE | DELETE | VIEW_PRICE | APPROVE | EXPORT
  entity    String
  entityId  String
  before    Json?
  after     Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([companyId, createdAt])
}

// Sequential document counters (Invoice/Order/Proposal/PO). One row per (companyId, kind, year).
// Numbers are never reused — allocation happens inside a transaction with a row lock.
model NumberSequence {
  id        String @id @default(cuid())
  companyId String
  kind      String // INVOICE | ORDER | PROPOSAL | PO
  year      Int
  lastValue Int    @default(0)

  @@unique([companyId, kind, year])
}

// ---------- AMC / O&M lifecycle (post-handover) ----------

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ServiceFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum VisitStatus {
  UPCOMING
  DUE
  DONE
  MISSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model ServiceContract {
  id            String           @id @default(cuid())
  companyId     String
  contractNo    String           @unique // GEC-AMC-2026-001
  orderId       String? // the plant this AMC covers
  clientName    String
  siteAddress   String
  startDate     DateTime
  endDate       DateTime
  annualValue   Decimal          @db.Decimal(14, 2) // *** ADMIN-ONLY — strip for EMPLOYEE ***
  frequency     ServiceFrequency @default(QUARTERLY)
  visitsPerYear Int              @default(4)
  scope         Json // {mechanical, electrical, chemical, consumablesIncluded, exclusions}
  status        ContractStatus   @default(ACTIVE)
  renewedFromId String? // the prior contract this one renews (renewal chain)
  createdById   String
  createdAt     DateTime         @default(now())

  order          Order?             @relation(fields: [orderId], references: [id])
  visits         MaintenanceVisit[]
  tickets        ServiceTicket[]
  communications Communication[]
  renewedFrom    ServiceContract?   @relation("Renewal", fields: [renewedFromId], references: [id])
  renewals       ServiceContract[]  @relation("Renewal")

  @@index([companyId, status])
  @@index([endDate])
  @@index([renewedFromId])
}

model MaintenanceVisit {
  id            String      @id @default(cuid())
  contractId    String
  seq           Int
  scheduledDate DateTime
  actualDate    DateTime?
  status        VisitStatus @default(UPCOMING)
  checklist     Json? // [{item, ok, note}]
  readings      Json? // {ph, do, flowKld, blowerHours, ...}
  notes         String?
  photos        Json? // [{url}]
  technicianId  String?
  lat           Float?
  lng           Float?
  createdAt     DateTime    @default(now())

  contract ServiceContract @relation(fields: [contractId], references: [id])

  @@index([contractId])
  @@index([scheduledDate, status])
}

model ServiceTicket {
  id           String         @id @default(cuid())
  companyId    String
  ticketNo     String         @unique // GEC-TKT-2026-001
  contractId   String?
  orderId      String?
  title        String
  description  String
  raisedBy     String // client name / staff
  priority     TicketPriority @default(MEDIUM)
  status       TicketStatus   @default(OPEN)
  assignedToId String?
  slaDueDate   DateTime?
  resolution   String?
  createdById  String
  createdAt    DateTime       @default(now())
  closedAt     DateTime?

  contract ServiceContract? @relation(fields: [contractId], references: [id])

  @@index([companyId, status])
  @@index([slaDueDate])
}

/// Tenant registry. companyId on every model refers to Company.id.
model Company {
  id        String   @id
  name      String
  gstin     String?
  stateCode String   @default("33")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
